# ========================================
# OIKYO SERVER - PRODUCTION ENVIRONMENT VARIABLES
# ========================================

# NODE ENVIRONMENT CONFIGURATION
NODE_ENV=production                    # Set to 'production' for live deployment, 'development' for local
PORT=5000                            # Port for the application (defaults to process.env.PORT or 5000)

# DATABASE CONFIGURATION
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database_name?retryWrites=true&w=majority
                                    # Production MongoDB Atlas URI

# REDIS CACHING (UPSTASH)
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
                                    # Upstash Redis REST API URL (optional, app will work without Redis)
UPSTASH_REDIS_REST_TOKEN=your-redis-token
                                    # Upstash Redis REST API token (optional, app will work without Redis)

# SECURITY CONFIGURATION
JWT_SECRET=your-super-secret-jwt-key-here-make-it-long-and-random
                                    # Secret key for JWT signing (at least 32 chars)
JWT_EXPIRES_IN=7d                   # JWT token expiration time (default: 7 days)

# EMAIL SERVICE (RESEND)
RESEND_API_KEY=re_1234567890abcdef  # Resend API key for sending emails

# FILE UPLOAD (CLOUDINARY)
CLOUDINARY_CLOUD_NAME=your_cloud_name
                                    # Cloudinary cloud name
CLOUDINARY_API_KEY=your_api_key      # Cloudinary API key
CLOUDINARY_API_SECRET=your_api_secret
                                    # Cloudinary API secret

# THIRD PARTY API INTEGRATIONS
MAHASAGAR_API_URL=https://api.mahasagar.com/v1/products
                                    # Mahasagar API base URL
MAHASAGAR_API_KEY=your_mahasagar_api_key
                                    # Mahasagar API key
MAHASAGAR_SECRET_KEY=your_mahasagar_secret
                                    # Mahasagar secret key (optional)

# PUSH NOTIFICATIONS (FIREBASE)
FIREBASE_SERVICE_ACCOUNT_KEY={"type": "service_account", "project_id": "...", "...": "..."}
                                    # Firebase service account key JSON (as single-line string)
FIREBASE_PROJECT_ID=your-project-id  # Firebase project ID

# APPLICATION CONFIGURATION
ADMIN_EMAIL=admin@yoursite.com      # Initial admin email for seeding
ADMIN_PASSWORD=your_admin_password  # Initial admin password (will be hashed)
INIT_KEY=your_init_key               # Key to protect initial admin registration
LOG_LEVEL=info                       # Log level: error, warn, info, http, verbose, debug

# RATE LIMITING
RATE_LIMIT_WINDOW_MS=900000          # Rate limit window in milliseconds (default: 15 minutes = 900000 ms)
RATE_LIMIT_MAX=100                   # Max requests per IP per window (default: 100)

# CORS CONFIGURATION
CORS_ORIGIN=http://localhost:3000    # Frontend domain for CORS (comma-separated for multiple domains)
FRONTEND_URL=https://oikyo.me        # Primary frontend URL for production

# NOTIFICATIONS
ADMIN_NOTIFICATION_EMAIL=notifications@yoursite.com
                                    # Email for admin notifications